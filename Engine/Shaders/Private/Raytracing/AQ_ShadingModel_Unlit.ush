//Shading Model: Unlit

Raysample[SampleIndex].ShadingModel = 5;

if ((Payload.Opacity > TOP_THRESHOLD) || (Payload.BlendingMode == 0))
{
	//Opaque
	Raysample[SampleIndex].Color = Payload.Radiance;
	Raysample[SampleIndex].Opacity = 1;
	
	break;
}
else
{
	//Transparent
	//Loop Again
	Raysample[SampleIndex].Color = Payload.Radiance;
	Raysample[SampleIndex].Opacity = Payload.Opacity;
	
	//Advance Ray
	Ray.Direction = SurfaceHit.IncidentVector;
	Ray.Origin = SurfaceHit.HitPosTranslucency;
}