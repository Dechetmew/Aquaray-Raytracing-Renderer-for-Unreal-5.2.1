//Shading Model: Dielectric

Raysample[SampleIndex].Color = Payload.BaseColor + (Payload.Radiance * 50.0f);
Raysample[SampleIndex].ShadingModel = 1;
	
#include "AQ_ShortRangeAO.ush"

float indirect = saturate(dot(Payload.WorldNormal, normalize(float3(1.0f, 1.0f, 1.0f))) + 1) * 0.3 + 0.7;
Raysample[SampleIndex].IndirectLightColor = indirect * IndirectLightColor;

#include "AQ_ShadingModel_Dielectric_Lighting.ush"
#include "AQ_ShadingModel_Dielectric_LightingPoint.ush"

break;